# EGM local development environment.
#
# Copy this file to .env for local experiments if you use a dotenv loader.
# Do not commit .env or any real credentials.

# Optional: needed only for real LLM-backed examples or tau/tau2 A/B runs.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_BASE=https://api.deepseek.com

# Optional: LiteLLM-compatible fallback used by some benchmark harnesses.
OPENAI_API_KEY=

# Optional: set by external benchmark harnesses when applicable.
ANTHROPIC_API_KEY=
